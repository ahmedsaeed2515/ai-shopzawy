- get_cheapest_products: "ارخص، أقل سعر، مناسب لميزانية"
- get_most_expensive_products: "أغلى، أحسن، premium, فاخر"
- filter_products_by_price: "تحت X، بين X وY، فوق X"
- compare_products: "قارن، الفرق، أيهم أحسن"
- get_best_deals: "عروض، خصومات، تخفيض"
- search_rag: كل الأسئلة العامة والاقتراحات
"""

class SmartAgent:
    def __init__(self, groq_api_key: str, rag_search_fn):
        self.client = Groq(api_key=groq_api_key)
        self.rag_search = rag_search_fn
        self.history = []

    def chat(self, user_message: str) -> str:
        self.history.append({"role": "user", "content": user_message})
        
        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            *self.history[-8:]  # Last 4 exchanges
        ]
        
        # First LLM call — may invoke tools
        response = self.client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=messages,
            tools=TOOLS,
            tool_choice="auto",
            temperature=0.3,  # Low for accuracy
            max_tokens=1000
        )
        
        message = response.choices[0].message
        
        # Handle tool calls
        if message.tool_calls:
            messages.append(message)
            
            for tool_call in message.tool_calls:
                result = self._execute_tool(
                    tool_call.function.name,
                    json.loads(tool_call.function.arguments)
                )
                
                messages.append({
                    "role": "tool",
                    "tool_call_id": tool_call.id,
                    "content": json.dumps(result, ensure_ascii=False)
                })
            
            # Second LLM call — formulate final response with tool results
            final_response = self.client.chat.completions.create(
                model="llama-3.3-70b-versatile",
                messages=messages,
                temperature=0.5,
                max_tokens=500
            )
            
            reply = final_response.choices[0].message.content
        else:
            reply = message.content
        
        self.history.append({"role": "assistant", "content": reply})
        return reply

    def _execute_tool(self, tool_name: str, args: dict) -> dict:
        """Execute the requested tool and return results."""
        tool_map = {
            "get_cheapest_products": get_cheapest_products,
            "get_most_expensive_products": get_most_expensive_products,
            "filter_products_by_price": filter_products_by_price,
            "compare_products": compare_products,
            "get_best_deals": get_best_deals,
            "check_product_availability": check_product_availability,
            "search_rag": self.rag_search,
        }
        
        func = tool_map.get(tool_name)
        if not func:
            return {"error": f"Tool {tool_name} not found"}
        
        try:
            result = func(**args)
            return {"success": True, "data": result, "count": len(result) if isinstance(result, list) else 1}
        except Exception as e:
            return {"success": False, "error": str(e)}
