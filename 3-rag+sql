from typing import Optional

DB_PATH = "aiShopzawy/database/shopzawy.db"

def get_cheapest_products(
    category: Optional[str] = None,
    brand: Optional[str] = None,
    max_price: Optional[float] = None,
    limit: int = 5
) -> list[dict]:
    """
    Returns cheapest available products.
    USE WHEN: customer asks for cheapest, lowest price, budget options.
    """
    query = """
        SELECT name_ar, brand_name, category_name,
               sale_price, base_price, discount_percent,
               stock_quantity, image_url, slug
        FROM products
        WHERE in_stock = 1 AND is_published = 1
    """
    params = []
    
    if category:
        query += " AND category_name LIKE ?"
        params.append(f"%{category}%")
    if brand:
        query += " AND brand_name LIKE ?"
        params.append(f"%{brand}%")
    if max_price:
        query += " AND sale_price <= ?"
        params.append(max_price)
    
    query += " ORDER BY sale_price ASC LIMIT ?"
    params.append(limit)
    
    return _execute(query, params)


def get_most_expensive_products(
    category: Optional[str] = None,
    brand: Optional[str] = None,
    limit: int = 5
) -> list[dict]:
    """
    Returns most expensive / premium products.
    USE WHEN: customer asks for best, premium, highest quality.
    """
    query = """
        SELECT name_ar, brand_name, category_name,
               sale_price, base_price, discount_percent,
               stock_quantity, image_url, slug
        FROM products
        WHERE in_stock = 1 AND is_published = 1
    """
    params = []
    if category:
        query += " AND category_name LIKE ?"
        params.append(f"%{category}%")
    if brand:
        query += " AND brand_name LIKE ?"
        params.append(f"%{brand}%")
    
    query += " ORDER BY sale_price DESC LIMIT ?"
    params.append(limit)
    
    return _execute(query, params)


def filter_products_by_price(
    min_price: float,
    max_price: float,
    category: Optional[str] = None,
    brand: Optional[str] = None,
    limit: int = 10
) -> list[dict]:
    """
    Returns products within price range.
    USE WHEN: customer says 'between X and Y' or 'under X' or 'above X'.
    """
    query = """
        SELECT name_ar, brand_name, category_name,
               sale_price, base_price, discount_percent,
               stock_quantity, image_url, slug
        FROM products
        WHERE in_stock = 1 AND is_published = 1
          AND sale_price BETWEEN ? AND ?
    """
    params = [min_price, max_price]
    
    if category:
        query += " AND category_name LIKE ?"
        params.append(f"%{category}%")
    if brand:
        query += " AND brand_name LIKE ?"
        params.append(f"%{brand}%")
    
    query += " ORDER BY sale_price ASC LIMIT ?"
    params.append(limit)
    
    return _execute(query, params)


def compare_products(product_names: list[str]) -> list[dict]:
    """
    Returns detailed data for specific products to compare.
    USE WHEN: customer wants to compare two or more specific products.
    """
    if not product_names:
        return []
    
    placeholders = ','.join(['?' for _ in product_names])
    query = f"""
        SELECT p.name_ar, p.brand_name, p.category_name,
               p.sale_price, p.base_price, p.discount_percent,
               p.stock_quantity, p.description, p.image_url,
               GROUP_CONCAT(pv.color || '/' || pv.size, ', ') as variants
        FROM products p
        LEFT JOIN product_variants pv ON pv.product_id = p.id
        WHERE p.name_ar LIKE '%{product_names[0]}%'
           OR p.name_ar LIKE '%{product_names[-1]}%'
        GROUP BY p.id
        LIMIT 10
    """
    return _execute(query, [])


def get_best_deals(limit: int = 10) -> list[dict]:
    """
    Returns products with highest discount percentage.
    USE WHEN: customer asks about offers, discounts, deals, sales.
    """
    query = """
        SELECT name_ar, brand_name, category_name,
               sale_price, base_price, discount_percent,
               stock_quantity, image_url, slug
        FROM products
        WHERE in_stock = 1 AND is_published = 1
          AND discount_percent > 0
        ORDER BY discount_percent DESC
        LIMIT ?
    """
    return _execute(query, [limit])


def check_product_availability(product_name: str) -> dict:
    """
    Checks if a specific product is available and its current price.
    USE WHEN: customer asks 'do you have X?' or 'is X available?'
    """
    query = """
        SELECT name_ar, brand_name, sale_price,
               in_stock, stock_quantity, image_url,
               (SELECT GROUP_CONCAT(color || ' ' || size || ' (' || stock || ')', ' | ')
                FROM product_variants WHERE product_id = products.id) as variants
        FROM products
        WHERE name_ar LIKE ? OR name_en LIKE ? OR slug LIKE ?
        LIMIT 3
    """
    search = f"%{product_name}%"
    results = _execute(query, [search, search, search])
    return results[0] if results else {"found": False, "message": f"مش لاقيش '{product_name}'"}


def _execute(query: str, params: list) -> list[dict]:
    """Execute query and return list of dicts."""
    try:
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        conn.execute("PRAGMA query_only = ON")  # Extra safety
        rows = conn.execute(query, params).fetchall()
        conn.close()
        return [dict(row) for row in rows]
    except Exception as e:
        return [{"error": str(e)}]
