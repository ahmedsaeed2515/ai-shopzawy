### 1.2 — JSON to SQLite Converter

```python
import sqlite3
import json
import os
from pathlib import Path

class JSONToSQLite:
    def __init__(self, db_path: str):
        self.db_path = db_path
        self.conn = sqlite3.connect(db_path)
        self.conn.row_factory = sqlite3.Row
        self.errors = []
        self.stats = {}

    def build_from_json(self, json_folder: str):
        """
        Main method — reads all JSON files and builds SQLite.
        Handles any JSON structure found in the folder.
        """
        self._create_schema()
        
        json_files = list(Path(json_folder).glob("**/*.json"))
        print(f"Found {len(json_files)} JSON files")
        
        for json_file in json_files:
            print(f"Processing: {json_file.name}")
            self._process_file(json_file)
        
        self._print_report()

    def _process_file(self, file_path: Path):
        """
        Reads one JSON file and routes data to correct table.
        Auto-detects data type from structure.
        """
        with open(file_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        # Handle both array and single object
        if isinstance(data, dict):
            # Could be {products: [...]} or a single product
            for key in ['products', 'items', 'data', 'results']:
                if key in data:
                    data = data[key]
                    break
            else:
                data = [data]
        
        if not data:
            return
            
        # Detect type from first record
        first = data[0] if data else {}
        data_type = self._detect_type(first, file_path.stem)
        
        handler = {
            'product': self._insert_product,
            'category': self._insert_category,
            'brand': self._insert_brand,
            'offer': self._insert_offer,
            'voucher': self._insert_voucher,
        }.get(data_type)
        
        if handler:
            count = 0
            for record in data:
                try:
                    handler(record)
                    count += 1
                except Exception as e:
                    self.errors.append(f"{file_path.name}: {e}")
            
            self.stats[data_type] = self.stats.get(data_type, 0) + count
            self.conn.commit()
            print(f"  ✅ Inserted {count} {data_type} records")
        else:
            print(f"  ⚠️  Unknown data type in {file_path.name} — skipping")

    def _detect_type(self, record: dict, filename: str) -> str:
        """
        Smart type detection based on fields and filename.
        YOU must adapt this based on actual JSON structure found.
        """
        filename_lower = filename.lower()
        
        if any(x in filename_lower for x in ['product', 'منتج', 'item']):
            return 'product'
        if any(x in filename_lower for x in ['category', 'categor', 'فئة', 'cat']):
            return 'category'
        if any(x in filename_lower for x in ['brand', 'ماركة', 'براند']):
            return 'brand'
        if any(x in filename_lower for x in ['offer', 'عرض', 'discount']):
            return 'offer'
        if any(x in filename_lower for x in ['voucher', 'coupon', 'كوبون']):
            return 'voucher'
        
        # Detect from fields if filename didn't help
        if any(k in record for k in ['price', 'sale_price', 'سعر', 'variants']):
            return 'product'
        if any(k in record for k in ['parent_id', 'parent_category']):
            return 'category'
        
        return 'unknown'

    def _insert_product(self, record: dict):
        """
        Insert one product. Map JSON fields to DB columns.
        YOU must adapt field names to match actual JSON.
        """
        # Extract nested price from variants if not at top level
        base_price = (
            record.get('price') or
            record.get('base_price') or
            record.get('original_price') or
            self._get_min_variant_price(record) or 0
        )
        
        sale_price = (
            record.get('sale_price') or
            record.get('discounted_price') or
            base_price
        )
        
        discount = 0
        if base_price > 0 and sale_price < base_price:
            discount = round((base_price - sale_price) / base_price * 100, 1)
        
        # Get stock
        stock_qty = (
            record.get('stock') or
            record.get('stock_quantity') or
            record.get('quantity') or
            self._get_total_variant_stock(record) or 0
        )
        
        in_stock = 1 if stock_qty > 0 else 0
        
        # Handle tags as comma-separated string
        tags = record.get('tags', [])
        if isinstance(tags, list):
            tags = ','.join(str(t) for t in tags)
        
        # Get image
        image = (
            record.get('image_url') or
            record.get('image') or
            record.get('thumbnail') or
            self._get_primary_image(record) or ''
        )
        
        # Get category and brand (handle nested objects)
        category_name = self._extract_name(record.get('category') or record.get('category_name', ''))
        brand_name = self._extract_name(record.get('brand') or record.get('brand_name', ''))
        
        product_id = self.conn.execute("""
            INSERT OR REPLACE INTO products (
                external_id, name_ar, name_en, slug, description, short_description,
                category_name, brand_name, base_price, sale_price, discount_percent,
                in_stock, stock_quantity, image_url, is_featured, is_published, tags
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            str(record.get('id', '')),
            record.get('name') or record.get('name_ar') or record.get('title', ''),
            record.get('name_en') or record.get('name_english', ''),
            record.get('slug', ''),
            record.get('description', ''),
            record.get('short_description', ''),
            category_name,
            brand_name,
            float(base_price),
            float(sale_price),
            float(discount),
            in_stock,
            int(stock_qty),
            image,
            int(bool(record.get('is_featured', False))),
            int(bool(record.get('is_published', True))),
            tags
        )).lastrowid
        
        # Insert variants
        variants = record.get('variants', record.get('product_variants', []))
        for v in variants:
            self._insert_variant(product_id, v)

    def _insert_variant(self, product_id: int, variant: dict):
        self.conn.execute("""
            INSERT OR REPLACE INTO product_variants
            (product_id, sku, color, size, price, sale_price, stock)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (
            product_id,
            variant.get('sku', ''),
            variant.get('color', ''),
            variant.get('size', ''),
            float(variant.get('price', 0)),
            float(variant.get('sale_price', variant.get('price', 0))),
            int(variant.get('stock', variant.get('quantity', 0)))
        ))

    def _get_min_variant_price(self, record: dict) -> float:
        variants = record.get('variants', [])
        if not variants:
            return 0
        prices = [v.get('sale_price') or v.get('price', 0) for v in variants]
        return min(p for p in prices if p > 0) if prices else 0

    def _get_total_variant_stock(self, record: dict) -> int:
        variants = record.get('variants', [])
        return sum(int(v.get('stock', v.get('quantity', 0))) for v in variants)

    def _get_primary_image(self, record: dict) -> str:
        images = record.get('images', record.get('product_images', []))
        if not images:
            return ''
        if isinstance(images[0], str):
            return images[0]
        return images[0].get('url', images[0].get('image_url', ''))

    def _extract_name(self, value) -> str:
        if isinstance(value, dict):
            return value.get('name') or value.get('name_ar') or value.get('title', '')
        return str(value) if value else ''

    def _print_report(self):
        print("\n" + "="*50)
        print("  SQLite Build Complete")
        print("="*50)
        for table, count in self.stats.items():
            print(f"  ✅ {table}: {count} records")
        if self.errors:
            print(f"\n  ⚠️  Errors ({len(self.errors)}):")
            for e in self.errors[:5]:
                print(f"     - {e}")
        
        # Verify
        tables = ['products', 'product_variants', 'categories', 'brands']
        print("\n  Database Verification:")
        for table in tables:
            count = self.conn.execute(f"SELECT COUNT(*) FROM {table}").fetchone()[0]
            print(f"  📊 {table}: {count} rows")
        print("="*50)
        print(f"\n  Database saved to: {self.db_path}")

if __name__ == "__main__":
    builder = JSONToSQLite("aiShopzawy/database/shopzawy.db")
    builder.build_from_json("aiShopzawy/data/")
    print("\nDone! Test with:")
    print("  python -c \"import sqlite3; db=sqlite3.connect('aiShopzawy/database/shopzawy.db'); print(db.execute('SELECT COUNT(*) FROM products').fetchone())\"")
```

